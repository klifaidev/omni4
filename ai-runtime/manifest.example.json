{
  "engine": "llama.cpp",
  "modelName": "OMNI Local Small",
  "binaryWin": "bin/llama-cli.exe",
  "binaryMac": "bin/llama-cli",
  "binaryLinux": "bin/llama-cli",
  "model": "models/omni-small.gguf",
  "timeoutMs": 90000,
  "args": [
    "-m",
    "{model}",
    "-f",
    "{promptFile}",
    "-n",
    "700",
    "--temp",
    "0.2",
    "--ctx-size",
    "8192",
    "--no-display-prompt"
  ]
}
